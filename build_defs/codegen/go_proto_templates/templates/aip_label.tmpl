// file: /home/malon/core/build_defs/codegen/go_proto_templates/templates/aip_label.tmpl
{{- $file := .File -}}
{{- $labels := getExt $file.Desc "malonaz.codegen.aip.v1.label" -}}
{{- if not $labels }}{{ skipGeneration }}{{ end -}}
// Code generated by protoc-templates. DO NOT EDIT.
// source: {{ $file.Desc.Path }}
package {{ .PackageName }}

{{- range $labels }}
    {{- $goName := .Key }}
    {{- if contains "/" .Key }}{{ $goName = last (splitList "/" .Key) }}{{ end }}
    {{- $goName = $goName | replace "-" "_" | camelcase }}
    type Label{{ $goName }} struct {
    GetKey func({{ range $i, $v := .KeyVariables }}{{ if $i }}, {{ end }}_{{ $v | replace "-" "_" | camelcase | untitle }} string{{ end }}) string
    {{- range .Values }}
        {{ . | replace "-" "_" | camelcase }} string
    {{- end }}
    }
{{- end }}

type LabelSet struct {
{{- range $labels }}
    {{- $goName := .Key }}
    {{- if contains "/" .Key }}{{ $goName = last (splitList "/" .Key) }}{{ end }}
    {{- $goName = $goName | replace "-" "_" | camelcase }}
    {{ $goName }} Label{{ $goName }}
{{- end }}
}

var Labels = LabelSet{
{{- range $labels }}
    {{- $goName := .Key }}
    {{- if contains "/" .Key }}{{ $goName = last (splitList "/" .Key) }}{{ end }}
    {{- $goName = $goName | replace "-" "_" | camelcase }}
    {{ $goName }}: Label{{ $goName }}{
    GetKey: func({{ range $i, $v := .KeyVariables }}{{ if $i }}, {{ end }}_{{ $v | replace "-" "_" | camelcase | untitle }} string{{ end }}) string {
    {{- if .KeyVariables }}
        return "{{ .Key }}" + "." + {{ range $i, $v := .KeyVariables }}{{ if $i }} + "." + {{ end }}_{{ $v | replace "-" "_" | camelcase | untitle }}{{ end }}
    {{- else }}
        return "{{ .Key }}"
    {{- end }}
    },
    {{- range .Values }}
        {{ . | replace "-" "_" | camelcase }}: "{{ . }}",
    {{- end }}
    },
{{- end }}
}
