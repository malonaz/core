{{- $file := .File -}}
{{- $hasLabels := false -}}
{{- range $file.Services -}}
    {{- $labels := getExt .Desc "malonaz.codegen.aip.v1.label" -}}
    {{- if $labels }}{{ $hasLabels = true }}{{ end -}}
{{- end -}}
{{- if not $hasLabels }}{{ skipGeneration }}{{ end -}}
// Code generated by protoc-templates. DO NOT EDIT.
// source: {{ $file.Desc.Path }}
package {{ .PackageName }}

{{- range $service := $file.Services }}
    {{- $labels := getExt $service.Desc "malonaz.codegen.aip.v1.label" }}
    {{- if not $labels }}{{ continue }}{{ end }}
    {{- $defaultHost := getExt $service.Desc "google.api.default_host" }}

    type {{ $service.GoName }}Labels struct {
    {{- range $labels }}
        {{ .Key | replace "-" "_" | camelcase }} string
    {{- end }}
    }

    var {{ $service.GoName }} = {{ $service.GoName }}Labels{
    {{- range $labels }}
        {{ .Key | replace "-" "_" | camelcase }}: "{{ $defaultHost }}/{{ .Key }}",
    {{- end }}
    }
{{- end }}
