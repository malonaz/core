{{- /* ################### TOPLINE VARIABLES ################### */ -}}
{{ $file := .File }}
{{ $generatedFile := .GeneratedFile -}}

// Code generated by protoc-templates. DO NOT EDIT.
// source: {{ $file.Desc.Path }}
package {{ .PackageName }}

{{ $skip := true }}

{{- range $service := $file.Services }}
    {{- $streams := getExt $service.Desc "malonaz.codegen.nats.v1.stream" }}
    {{- if not $streams }}{{ continue }}{{ end }}
    {{- $skip = false }}

    {{- range $streamOpts := $streams }}
        {{- $streamFQN := $streamOpts.GetName }}
        {{- $streamSuffix := regexReplaceAll "^.*\\.v[0-9]+\\." $streamFQN "" | replace "." "-" | camelcase }}
        {{- $streamGoName := printf "%s%sStream" $service.GoName $streamSuffix }}
        {{- $streamVarName := $streamGoName | untitle }}

        var (
        {{ $streamVarName }}Once {{ fqn "sync" "Once" }}
        {{ $streamVarName }}Val *{{ $streamGoName }}
        )

        type {{ $streamGoName }} struct {
        stream *{{ fqnCore "go/nats" "Stream" }}
        }

        func Get{{ $streamGoName }}() *{{ $streamGoName }} {
        {{ $streamVarName }}Once.Do(func() {
        {{ $streamVarName }}Val = &{{ $streamGoName }}{
        stream: {{ fqnCore "go/nats" "NewStream" }}(&{{ fqnCore "genproto/nats/v1" "StreamOptions" }}{Name: "{{ $streamFQN }}"}),
        }
        })
        return {{ $streamVarName }}Val
        }

        func (s *{{ $streamGoName }}) Get() *{{ fqnCore "go/nats" "Stream" }} {
        return s.stream
        }
    {{- end }}
{{ end }}

{{ if $skip }}{{ skipGeneration }}{{ end }}
